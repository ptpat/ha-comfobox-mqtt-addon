<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, &#xD;&#xA;            log4net" />
    <sectionGroup name="applicationSettings" type="System.Configuration.ApplicationSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="ComfoBoxLib.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
      <section name="ComfoBoxMqtt.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
  </startup>
  <log4net>
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="ComfoboxConsole_Log.txt" />
      <appendToFile value="true" />
      <rollingStyle value="Size" />
      <maxSizeRollBackups value="5" />
      <maximumFileSize value="10MB" />
      <staticLogFileName value="true" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %level %logger - %message%newline" />
      </layout>
    </appender>
    <!--<appender name="ColoredConsoleAppender" type="log4net.Appender.ColoredConsoleAppender">
      <mapping>
        <level value="ERROR" />
        <foreColor value="White" />
        <backColor value="Red, HighIntensity" />
      </mapping>
      <mapping>
        <level value="DEBUG" />
        <backColor value="Green" />
      </mapping>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
      </layout>
    </appender>-->
    <appender name="ConsoleAppender" type="log4net.Appender.ConsoleAppender">
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date [%thread] %-5level %logger [%property{NDC}] - %message%newline" />
      </layout>
    </appender>
    <root>
      <level value="DEBUG" />
      <appender-ref ref="RollingFileAppender" />
      <appender-ref ref="ConsoleAppender" />
    </root>
  </log4net>
  <applicationSettings>
    <ComfoBoxLib.Properties.Settings>
      <setting name="Baudrate" serializeAs="String">
        <value>76800</value>
      </setting>
      <setting name="Port" serializeAs="String">
        <value>COM8</value>
      </setting>
      <setting name="BacnetClientId" serializeAs="String">
        <value>3</value>
      </setting>
      <setting name="BacnetMasterId" serializeAs="String">
        <value>1</value>
      </setting>
      <setting name="MqttNoResponseTimeout" serializeAs="String">
        <value>00:00:30</value>
      </setting>
      <setting name="ExpertMode" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="MaxNumberOfWritesPer24h" serializeAs="String">
        <value>200</value>
      </setting>
      <setting name="MqttBrokerAddress" serializeAs="String">
        <value>localhost</value>
      </setting>
    </ComfoBoxLib.Properties.Settings>
    <ComfoBoxMqtt.Properties.Settings>
      <setting name="UseMqttRetain" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="MqttQoS" serializeAs="String">
        <value>0</value>
      </setting>
      <setting name="PrimaryStatesRefreshRate" serializeAs="String">
        <value>00:01:00</value>
      </setting>
      <setting name="SecondaryStatesRefreshRate" serializeAs="String">
        <value>00:05:00</value>
      </setting>
      <setting name="PrimaryConfigStatesRefreshRate" serializeAs="String">
        <value>00:01:00</value>
      </setting>
      <setting name="SecondaryConfigStatesRefresh" serializeAs="String">
        <value>01:00:00</value>
      </setting>
      <setting name="BaseTopic" serializeAs="String">
        <value>ComfoBox</value>
      </setting>
      <setting name="WriteTopicsToFile" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="WriteTopicsFilePath" serializeAs="String">
        <value>..\..\..\..\docs\topics.md</value>
      </setting>
      <setting name="PollSpecialValuesIntervalInMs" serializeAs="String">
        <value>1000</value>
      </setting>
      <setting name="SpecialSubTopic" serializeAs="String">
        <value>Special</value>
      </setting>
      <setting name="VirtualTopic" serializeAs="String">
        <value>Virtual</value>
      </setting>
    </ComfoBoxMqtt.Properties.Settings>
  </applicationSettings>
</configuration>